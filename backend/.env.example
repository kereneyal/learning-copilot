# ── Server ───────────────────────────────────────────────────────────────────
# Structured logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log format: "json" for production (default) | "text" for local dev readability
LOG_FORMAT=json
# Uvicorn worker processes.
# Keep at 1 while using SQLite + ChromaDB PersistentClient (file-locking constraint).
# Increase only after migrating to PostgreSQL + ChromaDB HTTP server.
WEB_CONCURRENCY=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default: localhost:3000 (development only). Set to your production domain.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, single-process only):
DATABASE_URL=sqlite:///./learning_copilot.db
# PostgreSQL (recommended for production, supports multiple workers):
# DATABASE_URL=postgresql://user:password@localhost:5432/learning_copilot

# ── File upload ───────────────────────────────────────────────────────────────
# Maximum file size in megabytes (default: 200 MB).
MAX_UPLOAD_MB=200

# ── Vector store ─────────────────────────────────────────────────────────────
# Path to ChromaDB persistent storage directory.
CHROMA_DB_PATH=./chroma_db

# ── External APIs ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── QA provider routing ───────────────────────────────────────────────────────
# Default generation provider: "ollama" (local) | "openai"
QA_PROVIDER_DEFAULT=ollama
# Provider for definition/acronym questions (higher quality needed for acronym expansions)
QA_PROVIDER_DEFINITION=openai
# OpenAI model to use when QA_PROVIDER_DEFINITION=openai
OPENAI_MODEL=gpt-4.1-mini
# OpenAI request timeout in seconds
OPENAI_TIMEOUT=30

# ── Ollama — local LLM server ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (must match the model pulled with `ollama pull`)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Internal Ollama API endpoint for embeddings (do not change unless Ollama version changes)
OLLAMA_EMBEDDING_ENDPOINT=/api/embed

# Generation model — CPU-only machine recommendations (fastest → slowest / params):
#
#   qwen2:0.5b    0.5B —  5–15 s/response  ← default, sub-30s target
#   llama3.2:1b   1.2B — 20–40 s/response  ← good quality/speed balance
#   phi3:mini     3.8B — 90–180 s/response   NOT a lightweight model despite the name
#   llama3:latest 8B   — 120–300 s/response  too slow for interactive use on CPU
#
# Pull your chosen model first:
#   ollama pull qwen2:0.5b
#   ollama pull llama3.2:1b
OLLAMA_GENERATION_MODEL=qwen2:0.5b

# Generation request timeout in seconds — must match the model above:
#   qwen2:0.5b   → 45
#   llama3.2:1b  → 90
#   phi3:mini    → 240
#   llama3:latest→ 300
OLLAMA_GENERATION_TIMEOUT=45

# ── Embedding performance ─────────────────────────────────────────────────────
# Parallel workers for embedding.  1 = serial (correct for CPU-only Ollama).
# Increase only for GPU-backed or remote API Ollama instances.
EMBED_WORKERS=1
# Per-request HTTP timeout for a single Ollama embedding call (seconds).
# nomic-embed-text warm: 1–5 s; cold start: up to 30 s.
# 90 s is generous but keeps a genuinely stuck Ollama from blocking forever.
# There is NO stage-level wall-clock timeout — embedding runs until done.
EMBED_SINGLE_TIMEOUT_S=90

# ── QA context limits ─────────────────────────────────────────────────────────
# Max chunks forwarded to the LLM (retrieval may return more; lowest-ranked are dropped).
QA_MAX_CONTEXT_CHUNKS=3
# Max characters per chunk in the prompt (longer chunks are hard-truncated with …).
# Total context budget = QA_MAX_CONTEXT_CHUNKS × QA_MAX_CHUNK_CHARS ≈ 1200 chars.
QA_MAX_CHUNK_CHARS=400

# ── Retrieval behaviour ───────────────────────────────────────────────────────
# Set to true to require Hebrew governance terms in retrieved chunks (off by default).
# Only useful for courses that are exclusively about corporate governance law.
DOMAIN_GATE_ENABLED=false

# ── Course aggregate generation (course summary + knowledge map) ──────────────
# Runs after per-document summary succeeds.  Both steps are best-effort and
# fully isolated — a failure here never affects document or summary status.
#
# Provider selection mirrors the summary provider logic:
#   "openai"  → uses OPENAI_API_KEY + AGGREGATES_MODEL  (recommended: fast, bounded)
#   "ollama"  → local Ollama — constrained by num_predict to cap response length
#   "auto"    → prefers OpenAI when OPENAI_API_KEY is set, otherwise Ollama
# Default: auto (same as summary).
# AGGREGATES_PROVIDER=openai
#
# Model override for both course summary and knowledge map.
# Leave empty to inherit from OPENAI_MODEL or OLLAMA_GENERATION_MODEL.
# AGGREGATES_MODEL=gpt-4.1-mini
#
# Per-call timeout in seconds.  Aggregates are best-effort; keep it short.
# For Ollama: num_predict caps token output so generation is bounded even
# if the client timeout fires before Ollama finishes internally.
AGGREGATES_TIMEOUT_S=30

# ── Summary generation ────────────────────────────────────────────────────────
# Provider for document summary generation.
#   "openai"  → uses OPENAI_API_KEY + SUMMARY_MODEL (fast, truly cancellable)
#   "ollama"  → local Ollama (slow on CPU, HTTP timeout does NOT stop Ollama
#               internally — CPU stays elevated until generation finishes)
# Default: "openai" when OPENAI_API_KEY is set, otherwise "ollama".
# Set explicitly to override auto-detection.
# SUMMARY_PROVIDER=openai

# Model override for summaries (applies to whichever provider is active).
# Leave empty to inherit from OPENAI_MODEL or OLLAMA_GENERATION_MODEL.
# SUMMARY_MODEL=gpt-4.1-mini

# Per-call timeout in seconds for summary generation.
# Keep short — summary is a best-effort background job that never blocks ingestion.
# Ollama note: this only stops the client from waiting; Ollama keeps generating.
SUMMARY_TIMEOUT_S=30

# ── Debug endpoints ───────────────────────────────────────────────────────────
# Expose /debug/retrieval and /debug/vector-store/course/{id} (off in production).
DEBUG_RETRIEVAL=false
